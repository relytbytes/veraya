{
  "expo": {
    "name": "Veraya",
    "slug": "restaurant-ops",
    "version": "1.0.1",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "platforms": [
      "ios",
      "android"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0C1A1E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.restaurantops.tylshe",
      "infoPlist": {
        "NSCameraUsageDescription": "Used for barcode scanning when receiving inventory and looking up menu items.",
        "NSMicrophoneUsageDescription": "Used for voice inventory counting — speak ingredient quantities hands-free.",
        "NSSpeechRecognitionUsageDescription": "Used to recognise spoken ingredient quantities during voice inventory counts.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0C1A1E"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.restaurantops.app"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Veraya to access the camera for barcode scanning."
        }
      ],
      "expo-secure-store",
      "expo-speech-recognition"
    ],
    "scheme": "restaurantops",
    "extra": {
      "apiUrl": "https://veraya.vercel.app",
      "router": {},
      "eas": {
        "projectId": "25044141-03b9-47a7-8671-8a2f4c1f0646"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "owner": "tyshelton",
    "updates": {
      "url": "https://u.expo.dev/25044141-03b9-47a7-8671-8a2f4c1f0646"
    }
  }
}
