# ── Veraya environment ────────────────────────────────────────────────────────
# Copy to .env and fill in. Never commit the real .env.

# Database — local dev uses a relative SQLite file; production uses Turso.
#   Local:      file:./prisma/dev.db
#   Production: libsql://<your-db>.turso.io
DATABASE_URL="file:./prisma/dev.db"
# Required for Turso in production (omit locally). DATABASE_AUTH_TOKEN is also accepted.
TURSO_AUTH_TOKEN=""

# NextAuth (v5). Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=""
# The deployed origin, e.g. https://veraya.vercel.app (http://localhost:3000 in dev)
NEXTAUTH_URL="http://localhost:3000"

# Vera intelligence (OpenAI)
OPENAI_API_KEY=""

# Stripe — reservation deposits / card-on-file
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Twilio — SMS confirmations / reminders / waitlist
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# Secret guarding the cron endpoint (Vercel Cron sends it as a bearer token)
CRON_SECRET=""
